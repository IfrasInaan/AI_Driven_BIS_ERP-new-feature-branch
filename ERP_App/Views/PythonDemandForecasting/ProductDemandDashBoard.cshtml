@model ERP_App.Models.StockMV2

@{
    ViewBag.Title = "Product Demand DashBoard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Product Demand Forecasting</h2>

@using (Html.BeginForm("ProductDemandDashBoard", "PythonDemandForecasting", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label for="invoiceDate">Select Month:</label>
        <input type="month" id="invoiceDate" name="invoiceDate" class="form-control" required />
    </div>

    <div class="form-group">
        <label for="productName">Select Product:</label>
        @Html.DropDownList("productName", ViewBag.Products as SelectList, "Select Product", new { @class = "form-control", required = "required" })
    </div>

    <button type="submit" class="btn btn-primary">Predict Demand</button>
}

@if (ViewBag.PredictedDemand != null)
{
    <div class="alert alert-info" style="margin-top:20px;">
        <strong>@ViewBag.PredictedDemand</strong>
    </div>
}
