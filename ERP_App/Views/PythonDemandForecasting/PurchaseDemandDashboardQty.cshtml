
@{
    ViewBag.Title = "PurchaseDemandDashboardQty";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Purchase Demand Forecasting</h2>

@using (Html.BeginForm("PurchaseDemandDashboardQty", "PythonDemandForecasting", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label for="invoiceDate">Select Month:</label>
        <input type="month" id="invoiceDate" name="invoiceDate" class="form-control" required />
    </div>

    <div class="form-group">
        <label for="productName">Select Product:</label>
        @Html.DropDownList("productName", ViewBag.Products as SelectList, "Select Product", new { @class = "form-control", required = "required" })
    </div>

    <button type="submit" class="btn btn-success">Predict Purchase Quantity</button>
}

@if (ViewBag.PredictedQuantity != null)
{
    <div class="alert alert-info mt-3">
        <strong>@ViewBag.PredictedQuantity</strong>
    </div>
}