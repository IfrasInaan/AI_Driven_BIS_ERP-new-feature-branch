
@{
    ViewBag.Title = "SupplierDemandDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Supplier Demand Forecasting</h2>

@using (Html.BeginForm("SupplierDemandDashboard", "PythonDemandForecasting", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label for="invoiceDate">Select Month:</label>
        <input type="month" id="invoiceDate" name="invoiceDate" class="form-control" required />
    </div>

    <div class="form-group">
        <label for="supplierName">Select Supplier:</label>
        @Html.DropDownList("supplierName", ViewBag.Suppliers as SelectList, "Select Supplier", new { @class = "form-control", required = "required" })
    </div>

    <button type="submit" class="btn btn-primary">Predict Total Amount</button>
}

@if (ViewBag.PredictedAmount != null)
{
    <div class="alert alert-info mt-3">
        <strong>@ViewBag.PredictedAmount</strong>
    </div>
}
